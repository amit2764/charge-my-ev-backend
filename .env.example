# Firebase service account settings
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-firebase-project.iam.gserviceaccount.com
# Either set FIREBASE_PRIVATE_KEY (escaped newlines as \n) or FIREBASE_PRIVATE_KEY_B64 (base64 of the private_key)
# Example (not real):
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
# Or set base64-encoded private key (recommended for CI):
# FIREBASE_PRIVATE_KEY_B64=BASE64_ENCODED_PRIVATE_KEY

# Optional runtime config
PORT=3000
NODE_ENV=development

# Twilio / SMS provider (for later)
#TWILIO_ACCOUNT_SID=
#TWILIO_AUTH_TOKEN=
#TWILIO_FROM_NUMBER=

# Stripe (for later)
#STRIPE_SECRET_KEY=
#STRIPE_WEBHOOK_SECRET=
